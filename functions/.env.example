SUPPORT_ALLOWED_DOMAIN=
SUPPORT_ALLOWED_EMAILS=

# Origins permitidas para chamadas cross-origin no navegador (CORS).
# Use vírgula para separar. Ex.:
# BACKOFFICE_ALLOWED_ORIGINS=https://backoffice-code-fusion.web.app,https://backoffice-code-fusion.firebaseapp.com,http://localhost:5002
BACKOFFICE_ALLOWED_ORIGINS=

TARGET_FIRESTORE_PROJECT_ID=rifa-73864
TARGET_FIRESTORE_DISABLE_EMULATOR=true

# GET /rifa/:id — por padrao usa o mesmo projeto que TARGET e a coleção "raffles".
# Se as rifas estiverem em outro projeto (ex.: app Rifa Digital), defina o projeto abaixo
# e conceda IAM na conta do secret TARGET_FIRESTORE_SERVICE_ACCOUNT_JSON (ou use uma SA desse projeto).
# RIFA_LOOKUP_PROJECT_ID=rifa-digital-f21e7
# RIFA_LOOKUP_COLLECTION=raffles
# Se o ID da rifa NAO e o documentId, mas um campo (ex.: id, rifaId), defina:
# RIFA_LOOKUP_MATCH_FIELD=id

FIRESTORE_USERS_COLLECTION=users
FIRESTORE_CREDIT_FIELD=credits
FIRESTORE_ALLOWED_UPDATE_FIELDS=supportStatus,supportNotes.latest,manualAccessUntil
FIRESTORE_ALLOW_NEGATIVE_CREDITS=false
FIRESTORE_MAX_CREDIT_DELTA=100000

AUDIT_COLLECTION=support_audit_logs

REVENUECAT_API_BASE_URL=https://api.revenuecat.com/v1
REVENUECAT_DEFAULT_PROJECT_LABEL=Projeto principal
REVENUECAT_PROMOTIONAL_PRO_ENTITLEMENT=pro

# Secrets locais do Emulator devem ficar em functions/.secret.local:
# REVENUECAT_PROJECTS_JSON=[{"projectId":"ios-main","label":"iOS Main","secretKey":"rc_live_xxx"},{"projectId":"android-main","label":"Android Main","secretKey":"rc_live_yyy"}]
# TARGET_FIRESTORE_SERVICE_ACCOUNT_JSON=

API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX_REQUESTS=60
API_RATE_LIMIT_REVENUECAT_PER_WINDOW=30
API_RATE_LIMIT_WRITE_PER_WINDOW=20
